{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "env": {
    "NEXT_PUBLIC_APP_NAME": "FleetFlow Premium"
  },
  "crons": [
    {
      "path": "/api/cron/auto-complete",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/reminder",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/generate-reports",
      "schedule": "30 16 * * *"
    }
  ]
}
