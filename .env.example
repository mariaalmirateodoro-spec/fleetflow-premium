# ============================================
# FleetFlow Premium – Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Supabase – required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (bypasses PostgREST — used by lib/db.ts via Drizzle).
# Get this from Supabase Dashboard > Settings > Database > Connection string >
# choose "Transaction" pooler mode (works from serverless functions like Vercel).
# Replace [YOUR-PASSWORD] in the copied string with your actual database password.
DATABASE_URL=postgres://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FleetFlow Premium

# Email (optional – Resend for transactional emails)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@fleetflow.com

# AI (optional – OpenAI for AI assistant features)
OPENAI_API_KEY=sk-your-key-here

# Auth
NEXTAUTH_SECRET=generate-a-random-secret-here
